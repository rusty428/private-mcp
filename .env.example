# Required: AWS account
AWS_ACCOUNT_ID=your-account-id
AWS_REGION=us-west-2

# Optional: Slack integration (leave empty if not using Slack)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CAPTURE_CHANNEL=

# Optional: Daily summary schedule (requires Slack). UTC hour to post, and timezone for date grouping.
DAILY_SUMMARY_HOUR=14
DAILY_SUMMARY_TIMEZONE=America/Los_Angeles

# Optional: additional CORS origins (comma-separated). Any localhost port is allowed automatically.
# Add your CloudFront domain here if deploying the UI
# ALLOWED_ORIGINS=https://your-domain.com

# Optional: Alert email for CloudWatch alarms (SNS topic + 5xx alarm created only if set)
# ALERT_EMAIL=your-email@example.com

# Optional: Set to "true" when upgrading from v1 to preserve your existing API key.
# The deploy will read your current API Gateway key and migrate it to DynamoDB.
# After deploy, run: npm run migrate (copies v1 data to v2 table + stamps identity fields on vectors)
# Remove this after upgrade is complete.
# UPGRADE_FROM_V1=true

# Optional: for conversation import script (scripts/import-conversations.ts)
# PRIVATE_MCP_ENDPOINT=https://<API_GATEWAY_ID>.execute-api.<REGION>.amazonaws.com
# PRIVATE_MCP_API_KEY=pmcp_<your_key>
