# Required: Slack integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CAPTURE_CHANNEL=your-channel-id

# Required: Daily summary schedule (UTC hour)
DAILY_SUMMARY_HOUR=14
DAILY_SUMMARY_TIMEZONE=America/Los_Angeles

# Optional: CORS origins (comma-separated, defaults to localhost:5173,localhost:3000)
# Add your CloudFront domain here if deploying the UI
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com

# Optional: Alert email for CloudWatch alarms (SNS topic + 5xx alarm created only if set)
# ALERT_EMAIL=your-email@example.com
